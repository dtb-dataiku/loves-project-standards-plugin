/* This file is the descriptor for the python runnable project-wiki-generator */
{
    "meta": {
        "label": "Project Wiki Starter",
        "description": "Create a starter wiki for the project.",
        "icon": "fas fa-marker"
    },

    "impersonate": false,
    "permissions": [],
    "resultType": "URL",
    "resultLabel": "Link to generated wiki",

    "macroRoles": [
        {
            "type": "PROJECT_MACROS"
        }
    ],

    "paramsPythonSetup": "get_options_wiki_generator.py",
    "params": [
        {
            "name": "use_status",
            "label": "Update project status",
            "type": "BOOLEAN",
            "defaultValue": false,
            "mandatory": true
        },
        {
            "name": "status",
            "label": "Project status",
            "type": "SELECT",
            "visibilityCondition": "model.use_status",
            "getChoicesFromPython": true,
            "disableAutoReload": true,
            "mandatory": true
        }/*,
        {
            "name": "use_metadata",
            "label": "Use project metadata",
            "description": "Use project short and long descriptions to seed wiki.",
            "type": "BOOLEAN",
            "defaultValue": true,
            "mandatory": true
        },
        {
            "name": "use_default_tags",
            "label": "Use default tags",
            "description": "Use default tags to select datasets to document.",
            "type": "BOOLEAN",
            "defaultValue": true,
            "mandatory": true
        },
        {
            "name": "selected_tags",
            "label": "Tag(s)",
            "type": "MULTISELECT",
            "visibilityCondition": "!model.use_default_tags",
            "getChoicesFromPython": true,
            "disableAutoReload": true
        },
        {
            "name": "overwrite",
            "label": "Overwrite existing wiki",
            "description": "Overwrite existing article titled Project Documentation.",
            "type": "BOOLEAN",
            "defaultValue": true,
            "mandatory": true
        }*/
    ]
}
